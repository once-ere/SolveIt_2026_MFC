/* Template file for PsiEv * *    A. Goh  Feb 1996     */:Evaluate:  BeginPackage["Quantum`Psi`"]:Evaluate:  Init::usage="Init[] initializes the external program PsiEv with defaults.":Evaluate:  Init::memerr="Memory allocation error: calloc failed.":Evaluate:  Done::usage="Done[] frees the memory used by PsiEv. Done should be called prior to uninstalling PsiEv.":Evaluate:  SetParms::usage="SetParms[jP0, lambda0, w0, t0] initializes PsiEv to use an infinite square-well \potential of width w0, an x-grid of jP0+1 points and values of lambda0 for lambda and t0 for current time. \The wavefunction and potential are reset to 0.":Evaluate:  SetParms::rngerr="Invalid parameter value.":Evaluate:  SetParms::memerr="Memory allocation error: calloc failed.":Evaluate:  SetPsiReal::usage="SetPsiReal[reallist] sets the real part of the wavefunction using reallist.":Evaluate:  SetPsiImag::usage= "SetPsiImag[reallist] sets the imaginary part of the wavefunction using reallist.":Evaluate:  SetPotential::usage="SetPotential[reallist] sets the potential using reallist.":Evaluate:  SetGaussian::usage= "SetGaussian[x0, sigmax0, p0] where sigmax0 > 0 sets the wavefunction to be that \of a Gaussian wavepacket of positional mean x0 and standard deviation sigmax0 and with mean momentum p0.":Evaluate:  NormalizePsi::usage= "NormalizePsi[] normalizes the wavefunction.":Evaluate:  SetSquarePotential::usage= "SetSquarePotential[{v0, x1, v1, x2, v2, ..., xn, vn}] sets the potential to be \v0 for 0<=x<x1, vi for xi<=x<x(i+1) where 1<=i<=n-1 and vn for xn<=x<=width of potential well.":Evaluate:  SetStepPotential::usage="SetStepPotential[v1, x0, v2] sets the potential to be v1 for 0<=x<x0 and v2 for \x0<=x<=width of potential well.":Evaluate:  SetTime::usage= "SetTime[t0] sets the simulation time to t0.":Evaluate:  GetPsi::usage= "GetPsi[jm] returns a list of the values of the wavefunction sampled at jm+1 \points evenly spaced through the potential well.":Evaluate:  GetPotential::usage= "GetPotential[jm] returns a list of the values of the potential function sampled \at jm+1 points evenly spaced through the potential well.":Evaluate:  GetProbDensity::usage= "GetProbDensity[jm] returns a list of the values of the square of the modulus of \the wavefunction sampled at jm+1 points evenly spaced through the potential well.":Evaluate:  GetProbability::usage= "GetProbability[x1, x2] returns the integral of the square of the modulus of the \wavefunction from x1 to x2.":Evaluate:  GetTime::usage="GetTime[] returns the current simulation time.":Evaluate:   GetDelta::usage="GetDelta[] returns the simulation time increment.":Evaluate:  GetParms::usage="GetParms[] returns a list of the current settings of the simulation parameters representing the \number of intervals the well is divided into, the value of lambda, the width of the well and the current simulation time.":Evaluate:  Evolve::usage="Evolve[deltat] evolves the wavefunction by a time interval deltat.":Evaluate:  Evolve::memerr="Memory allocation error: calloc failed.":Evaluate:  Begin["`Private`"]:Begin::Function:        init:Pattern:         Init[]:Arguments::ArgumentTypes:   Manual:ReturnType:      Manual:End::Begin::Function:        done:Pattern:         Done[]:Arguments::ArgumentTypes:   Manual:ReturnType:      Manual:End::Begin::Function:        setparms:Pattern:         SetParms[jP_Integer, lambda_, deltaX_, t_]:Arguments:       {jP, lambda, deltaX, t}:ArgumentTypes:   {Integer, Real, Real, Real}:ReturnType:      Manual:End::Begin::Function:        setpsireal:Pattern:         SetPsiReal[psiRe_]:Arguments:       {psiRe}:ArgumentTypes:   {RealList}:ReturnType:      Manual:End::Begin::Function:        setpsiimag:Pattern:         SetPsiImag[psiIm_]:Arguments:       {psiIm}:ArgumentTypes:   {RealList}:ReturnType:      Manual:End::Begin::Function:        setpotential:Pattern:         SetPotential[v_]:Arguments:       {v}:ArgumentTypes:   {RealList}:ReturnType:      Manual:End::Begin::Function:        setgaussian:Pattern:         SetGaussian[x0_, sigmax0_, p0_]/;sigmax0>0:Arguments:       {x0, sigmax0, p0}:ArgumentTypes:   {Real, Real, Real}:ReturnType:      Manual:End::Begin::Function:        normalizepsi:Pattern:         NormalizePsi[]:Arguments::ArgumentTypes:   Manual:ReturnType:      Manual:End::Begin::Function:        setsquarepotential:Pattern:         SetSquarePotential[spdata_]/;OddQ[Length[spdata]]:Arguments:       {spdata}:ArgumentTypes:   {RealList}:ReturnType:      Manual:End::Begin::Function:        setsteppotential:Pattern:         SetStepPotential[v1_, x0_, v2_]:Arguments:       {v1, x0, v2}:ArgumentTypes:   {Real, Real, Real}:ReturnType:      Manual:End::Begin::Function:        settime:Pattern:         SetTime[t_]:Arguments:       {t}:ArgumentTypes:   {Real}:ReturnType:      Manual:End::Begin::Function:        getpsi:Pattern:         GetPsi[jm_Integer]:Arguments:       {jm}:ArgumentTypes:   {Integer}:ReturnType:      Manual:End::Begin::Function:        getpotential:Pattern:         GetPotential[jm_Integer]:Arguments:       {jm}:ArgumentTypes:   {Integer}:ReturnType:      Manual:End::Begin::Function:        getprobdensity:Pattern:         GetProbDensity[jm_Integer]:Arguments:       {jm}:ArgumentTypes:   {Integer}:ReturnType:      Manual:End::Begin::Function:        getprobability:Pattern:         GetProbability[x1_, x2_]:Arguments:       {x1, x2}:ArgumentTypes:   {Real, Real}:ReturnType:      Manual:End::Begin::Function:        gettime:Pattern:         GetTime[]:Arguments::ArgumentTypes:   Manual:ReturnType:      Manual:End::Begin::Function:        getdelta:Pattern:         GetDelta[]:Arguments::ArgumentTypes:   Manual:ReturnType:      Real:End::Begin::Function:        getparms:Pattern:         GetParms[]:Arguments::ArgumentTypes:   Manual:ReturnType:      Manual:End::Begin::Function:        evolve:Pattern:         Evolve[deltaT_]/;deltaT>=0:Arguments:       {deltaT}:ArgumentTypes:   {Real}:ReturnType:      Manual:End::Evaluate:  End[]:Evaluate:  EndPackage[]