Notebook[{
Cell[BoxData[
    \(Off[General::"\<spell1\>"]\)], "Input"],

Cell["\<\
eq1=B \[Equal] (zFar+zNear)/(zNear - zFar)\
\>", "Text"],

Cell[BoxData[
    \(B == \(zFar + zNear\)\/\(\(-zFar\) + zNear\)\)], "Text"],

Cell["\<\
eq2=C \[Equal] (2 zFar zNear)/(zNear - zFar)\
\>", "Text"],

Cell[BoxData[
    \(C == \(2\ zFar\ zNear\)\/\(\(-zFar\) + zNear\)\)], "Text"],

Cell["Solve[{eq1,eq2},{zFar ,zNear}]", "Text"],

Cell[BoxData[
    \({{zFar \[Rule] C\/\(1 + B\), 
        zNear \[Rule] C\/\(\(-1\) + B\)}}\)], "Text"],

Cell["\<\
Solve[{B \[Equal] (2)/(zNear - zFar),C \[Equal] (zFar+zNear)/(zNear - \
zFar)},{zFar ,zNear}]\
\>", "Text"],

Cell[BoxData[
    \({{zFar \[Rule] \(-\(\(1 - C\)\/B\)\), 
        zNear \[Rule] \(-\(\(\(-1\) - C\)\/B\)\)}}\)], "Text"],

Cell[CellGroupData[{

Cell["\<\
glFrustum
\
\>", "Subsubsection"],

Cell["\<\
Solve[{1/p22 \[Equal] (t-b)/(2 zNear ),0 \[Equal] (t + b)},{t ,b}]\
\>", "Text"],

Cell[BoxData[
    \({{t \[Rule] zNear\/p22, b \[Rule] \(-\(zNear\/p22\)\)}}\)], "Text"],

Cell["\<\
Solve[{p33\[Equal]-(far+near)/(far-near),p34\[Equal]-(2 far \
near)/(far-near)},{near,far}][[1]]\
\>", "Text"],

Cell[BoxData[
    \({near \[Rule] p34\/\(\(-1\) + p33\), 
      far \[Rule] p34\/\(1 + p33\)}\)], "Text"],

Cell["\<\
Solve[{p11\[Equal](2 \
near)/(right-left),p13\[Equal](right+left)/(right-left)},{right,left}][[1]]\
\>", "Text"],

Cell[BoxData[
    \({right \[Rule] \(-\(\(\(-near\) - near\ p13\)\/p11\)\), 
      left \[Rule] \(near\ \((\(-1\) + p13)\)\)\/p11}\)], "Text"],

Cell["\<\
Solve[{p22\[Equal](2 \
near)/(top-bottom),p23\[Equal](top+bottom)/(top-bottom)},{top,bottom}][[1]]\
\>", "Text"],

Cell[BoxData[
    \({top \[Rule] \(-\(\(\(-near\) - near\ p23\)\/p22\)\), 
      bottom \[Rule] \(near\ \((\(-1\) + p23)\)\)\/p22}\)], "Text"],

Cell[BoxData[
    \({Factor[\(-\(\(\(-near\) - near\ p23\)\/p22\)\)], 
      Factor[\(-\(\(\(-near\) - near\ p13\)\/p11\)\)]}\)], "Text"],

Cell[BoxData[
    \({\(near\ \((1 + p23)\)\)\/p22, \(near\ \((1 + p13)\)\)\/p11}\)], "Text"],

Cell[BoxData[
    \(r = {x, y, z}; R = \@\(r . r\); m = {0, 0, \[Mu]};\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(B = \(3\ \((r . m)\) r/\((r . r)\) - m\)\/R\^3\)], "Input"],

Cell[BoxData[
    \({\(3\ x\ z\ \[Mu]\)\/\((x\^2 + y\^2 + z\^2)\)\^\(5/2\), \(3\ y\ z\ \
\[Mu]\)\/\((x\^2 + y\^2 + z\^2)\)\^\(5/2\), \(\(-\[Mu]\) + \(3\ z\^2\ \[Mu]\)\
\/\(x\^2 + y\^2 + z\^2\)\)\/\((x\^2 + y\^2 + z\^2)\)\^\(3/2\)}\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(\[CapitalPhi] = 
      2\ \[Pi]\ \(\[Integral]\_0\%a\((\(\(-\[Mu]\) + \(3\ z\^2\ \[Mu]\)\/\(\
\[Rho]\^2 + z\^2\)\)\/\((\[Rho]\^2 + z\^2)\)\^\(3/2\))\) \[Rho] \
\[DifferentialD]\[Rho]\)\)], "Input"],

Cell[BoxData[
    \(\(2\ a\^2\ \[Pi]\ \[Mu]\)\/\((a\^2 + z\^2)\)\^\(3/2\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(D[\[CapitalPhi], z]\)], "Input"],

Cell[BoxData[
    \(\(-\(\(6\ a\^2\ \[Pi]\ z\ \[Mu]\)\/\((a\^2 + z\^2)\)\^\(5/2\)\)\)\)], \
"Output"]
}, Open  ]],

Cell["k={0,0,1};", "Text"],

Cell[BoxData[
    \(k . \((dr\ \[Times]\ 
            B)\) = \ \(dr . \((B\ \[Times]\ 
              k)\) = \(\(\(3\ \ z\ \[Mu]\)\/\((x\^2 + y\^2 + z\^2)\)\^\(5/2\)\
\) {y, \(-x\), 0} . {dx, dy, 
                0} = \(-\(\(3\ a\^2\ z\ \[Mu]\)\/\((x\^2 + y\^2 + \
z\^2)\)\^\(5/2\)\)\) d\[Theta]\)\)\)], "Text"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\[ScriptCapitalF] = \(-2\)\ \[Pi]\ \[ScriptCapitalI]\ \(3\ a\^2\ z\ \
\[Mu]\)\/\((x\^2 + y\^2 + z\^2)\)\^\(5/2\) /. {\[Mu] \[Rule] \(\(\(\ \
\)\(\[Mu]\_0\)\)\/\(4  \[Pi]\)\) M\_0, x\^2 + y\^2 \[Rule] a\^2}\)], "Input"],

Cell[BoxData[
    \(\(-\(\(3\ a\^2\ z\ \[ScriptCapitalI]\ M\_0\ \[Mu]\_0\)\/\(2\ \((a\^2 + \
z\^2)\)\^\(5/2\)\)\)\)\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(eq1 = \ 
      L\ D[\ \[ScriptCapitalI][t], t] + \ \[ScriptCapitalI][
              t]\ \ \[ScriptCapitalR]\  \[Equal] \(-\ 
          D[\[CapitalPhi] /. {\[Mu] \[Rule] \(\(\(\ \)\(\[Mu]\_0\)\)\/\(4  \
\[Pi]\)\) M\_0, z \[Rule] z[t]}, t]\)\)], "Input"],

Cell[BoxData[
    RowBox[{
      RowBox[{\(\[ScriptCapitalR]\ \[ScriptCapitalI][t]\), "+", 
        RowBox[{"L", " ", 
          RowBox[{
            SuperscriptBox["\[ScriptCapitalI]", "\[Prime]",
              MultilineFunction->None], "[", "t", "]"}]}]}], "==", 
      FractionBox[
        RowBox[{
        "3", " ", \(a\^2\), " ", \(M\_0\), " ", \(\[Mu]\_0\), " ", \(z[t]\), 
          " ", 
          RowBox[{
            SuperscriptBox["z", "\[Prime]",
              MultilineFunction->None], "[", "t", 
            "]"}]}], \(2\ \((a\^2 + z[t]\^2)\)\^\(5/2\)\)]}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(eq2 = \[ScriptCapitalM]\ \(z''\)[
            t] \[Equal] \((\[ScriptCapitalF] /. {\[ScriptCapitalI] -> \
\[ScriptCapitalI][t], 
                z \[Rule] 
                  z[t]})\) - \(\(\[ScriptCapitalM]\)\(\ \)\(g\)\(\ \)\)\)], \
"Input",
  CellTags->"DSolve"],

Cell[BoxData[
    RowBox[{
      RowBox[{"\[ScriptCapitalM]", " ", 
        RowBox[{
          SuperscriptBox["z", "\[Prime]\[Prime]",
            MultilineFunction->None], "[", "t", "]"}]}], 
      "==", \(\(-g\)\ \[ScriptCapitalM] - \(3\ a\^2\ M\_0\ \[Mu]\_0\ z[t]\ \
\[ScriptCapitalI][t]\)\/\(2\ \((a\^2 + z[t]\^2)\)\^\(5/2\)\)\)}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(eqs = {eq1, eq2}\)], "Input"],

Cell[BoxData[
    RowBox[{"{", 
      RowBox[{
        RowBox[{
          RowBox[{\(\[ScriptCapitalR]\ \[ScriptCapitalI][t]\), "+", 
            RowBox[{"L", " ", 
              RowBox[{
                SuperscriptBox["\[ScriptCapitalI]", "\[Prime]",
                  MultilineFunction->None], "[", "t", "]"}]}]}], "==", 
          FractionBox[
            RowBox[{
            "3", " ", \(a\^2\), " ", \(M\_0\), " ", \(\[Mu]\_0\), 
              " ", \(z[t]\), " ", 
              RowBox[{
                SuperscriptBox["z", "\[Prime]",
                  MultilineFunction->None], "[", "t", 
                "]"}]}], \(2\ \((a\^2 + z[t]\^2)\)\^\(5/2\)\)]}], ",", 
        RowBox[{
          RowBox[{"\[ScriptCapitalM]", " ", 
            RowBox[{
              SuperscriptBox["z", "\[Prime]\[Prime]",
                MultilineFunction->None], "[", "t", "]"}]}], 
          "==", \(\(-g\)\ \[ScriptCapitalM] - \(3\ a\^2\ M\_0\ \[Mu]\_0\ z[t]\
\ \[ScriptCapitalI][t]\)\/\(2\ \((a\^2 + z[t]\^2)\)\^\(5/2\)\)\)}]}], 
      "}"}]], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(Eqs = 
      Simplify[eqs /. {a \[Rule] 1, \[ScriptCapitalM] \[Rule] 1, \ 
            g \[Rule] 1, \[ScriptCapitalR] \[Rule] 1, L \[Rule] 1, 
            M\_0 \[Rule] 1, \ \[Mu]\_0\  \[Rule] 1}]\)], "Input"],

Cell[BoxData[
    RowBox[{"{", 
      RowBox[{
        RowBox[{
          RowBox[{\(\[ScriptCapitalI][t]\), "+", 
            RowBox[{
              SuperscriptBox["\[ScriptCapitalI]", "\[Prime]",
                MultilineFunction->None], "[", "t", "]"}]}], "==", 
          FractionBox[
            RowBox[{"3", " ", \(z[t]\), " ", 
              RowBox[{
                SuperscriptBox["z", "\[Prime]",
                  MultilineFunction->None], "[", "t", 
                "]"}]}], \(2\ \((1 + z[t]\^2)\)\^\(5/2\)\)]}], ",", 
        RowBox[{
          RowBox[{
          "1", "+", \(\(3\ z[t]\ \[ScriptCapitalI][
                    t]\)\/\(2\ \((1 + z[t]\^2)\)\^\(5/2\)\)\), "+", 
            RowBox[{
              SuperscriptBox["z", "\[Prime]\[Prime]",
                MultilineFunction->None], "[", "t", "]"}]}], "==", "0"}]}], 
      "}"}]], "Output"]
}, Open  ]],

Cell[BoxData[
    \(\(T = 40;\)\)], "Input"],

Cell[BoxData[
    RowBox[{
      RowBox[{"solution", "=", 
        RowBox[{"NDSolve", "[", 
          RowBox[{
            RowBox[{"{", 
              RowBox[{"Eqs", ",", \(\[ScriptCapitalI][0] \[Equal] 0\), ",", 
                RowBox[{
                  RowBox[{
                    SuperscriptBox["z", "\[Prime]",
                      MultilineFunction->None], "[", "0", "]"}], " ", 
                  "\[Equal]", " ", "0"}], ",", \(z[0]\  \[Equal] \ 10\)}], 
              "}"}], ",", \({z, \[ScriptCapitalI]}\), ",", \({t, 0, T}\)}], 
          "]"}]}], ";"}]], "Input",
  CellTags->"DSolve"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(Plot[Evaluate[z[t] /. solution], {t, 0, T}];\)\)], "Input"],

