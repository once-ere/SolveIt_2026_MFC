Cell[CellGroupData[{

Cell[BoxData[
    \(Eqs = 
      Simplify[eqs /. {a \[Rule] 1, \[ScriptCapitalM] \[Rule] 1\/100, \ 
            g \[Rule] 1, \[ScriptCapitalR] \[Rule] 0, L \[Rule] 1, 
            M\_0 \[Rule] 1, \ \[Mu]\_0\  \[Rule] 1}]\)], "Input"],

Cell[BoxData[
    RowBox[{"{", 
      RowBox[{
        RowBox[{
          RowBox[{
            SuperscriptBox["\[ScriptCapitalI]", "\[Prime]",
              MultilineFunction->None], "[", "t", "]"}], "==", 
          FractionBox[
            RowBox[{"3", " ", \(z[t]\), " ", 
              RowBox[{
                SuperscriptBox["z", "\[Prime]",
                  MultilineFunction->None], "[", "t", 
                "]"}]}], \(2\ \((1 + z[t]\^2)\)\^\(5/2\)\)]}], ",", 
        RowBox[{
          RowBox[{\(1\/100\), " ", 
            RowBox[{"(", 
              RowBox[{
              "1", "+", \(\(150\ z[t]\ \[ScriptCapitalI][
                        t]\)\/\((1 + z[t]\^2)\)\^\(5/2\)\), "+", 
                RowBox[{
                  SuperscriptBox["z", "\[Prime]\[Prime]",
                    MultilineFunction->None], "[", "t", "]"}]}], ")"}]}], "==",
           "0"}]}], "}"}]], "Output"]
}, Open  ]],

Cell[BoxData[
    RowBox[{
      RowBox[{"solution", "=", 
        RowBox[{"NDSolve", "[", 
          RowBox[{
            RowBox[{"{", 
              RowBox[{"Eqs", ",", \(\[ScriptCapitalI][0] \[Equal] 0\), ",", 
                RowBox[{
                  RowBox[{
                    SuperscriptBox["z", "\[Prime]",
                      MultilineFunction->None], "[", "0", "]"}], " ", 
                  "\[Equal]", " ", "0"}], ",", \(z[0]\  \[Equal] \ 10\)}], 
              "}"}], ",", \({z, \[ScriptCapitalI]}\), ",", \({t, 0, T}\)}], 
          "]"}]}], ";"}]], "Input",
  CellTags->"DSolve"],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(Plot[Evaluate[z[t] /. solution], {t, 0, T}];\)\)], "Input"],

