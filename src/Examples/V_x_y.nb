Notebook[{
Cell[BoxData[
    \(f[x_, y_] := \((1 - x/4)\)*\((1 + x/4)\)*\((1 - x/4)\)*\((1 + x/4)\) + 
        y*y*\((0.25 + 6.25*Exp[\(-x\)*x])\)\)], "Input"],

Cell[CellGroupData[{

Cell[BoxData[
    \(f[0, \ 5]\)], "Input"],

Cell[BoxData[
    \(163.5`\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(f[4, 0]\)], "Input"],

Cell[BoxData[
    \(0\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(f[0, 0]\)], "Input"],

Cell[BoxData[
    \(1\)], "Output"]
}, Open  ]],

Cell[CellGroupData[{

Cell[BoxData[
    \(\(ContourPlot[f[x, \ y], {x, \(-5\), 5}, {y, \(-5\), 5}];\)\)], "Input"],

Cell[GraphicsData["PostScript", "\<\
