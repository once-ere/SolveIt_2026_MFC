IDD_WAVENUMBERS DIALOG DISCARDABLE  0, 0, 254, 149
STYLE DS_MODALFRAME | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Superposition of  Waves"
FONT 8, "MS Sans Serif"
BEGIN
    DEFPUSHBUTTON   "OK",1,0,135,50,14
    PUSHBUTTON      "Cancel",2,204,135,50,14
    EDITTEXT        IDC_EDIT_NUMBERWAVENUMBERS,89,27,50,14,ES_AUTOHSCROLL
    LTEXT           "Number of wave numbers:",IDC_STATIC,1,31,84,13
    EDITTEXT        IDC_EDIT_RATIO,89,61,50,14,ES_AUTOHSCROLL
    LTEXT           "Ratio of successive wave numbers:",IDC_STATIC,1,64,77,
                    18
    EDITTEXT        IDC_EDIT_WAVELENGTH,89,44,50,14,ES_AUTOHSCROLL
    LTEXT           "Wavelength of first wave number:",IDC_STATIC,1,43,76,17
    EDITTEXT        IDC_EDIT_DT,89,78,50,14,ES_AUTOHSCROLL
    LTEXT           "Time step:",IDC_STATIC,0,83,52,11
    PUSHBUTTON      "Apply",IDC_APPLY,204,0,50,14
    GROUPBOX        "Examples",IDC_STATIC,148,17,103,73
    CONTROL         "Momentum eigenstate",IDC_RADIO1,"Button",
                    BS_AUTORADIOBUTTON | WS_GROUP,157,27,88,12
    CONTROL         "Pair",IDC_RADIO2,"Button",BS_AUTORADIOBUTTON,157,39,70,
                    12
    CONTROL         "Triple",IDC_RADIO3,"Button",BS_AUTORADIOBUTTON,157,51,
                    70,12
    CONTROL         "Localized",IDC_RADIO4,"Button",BS_AUTORADIOBUTTON,157,
                    63,70,12
    CONTROL         "Dispersion",IDC_RADIO5,"Button",BS_AUTORADIOBUTTON,157,
                    75,70,12
    LTEXT           "The red horizontal axis is the x-axis.\r\nThe blue axis normal to the screen is the time axis.\r\nThe green vertical axis is the quantum mechanical relative probability density.",
                    IDC_STATIC,0,106,248,29
    CONTROL         278,IDC_STATIC,"Static",SS_BITMAP | SS_REALSIZEIMAGE,0,4,
                    113,22
END


