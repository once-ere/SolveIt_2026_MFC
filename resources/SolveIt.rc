IDR_EXAMPLES_MENU MENU DISCARDABLE 
BEGIN
    POPUP "_POPUP_"
    BEGIN
        MENUITEM "Copy",                        ID_POPUP_COPY
        MENUITEM "Cut",                         ID_POPUP_CUT
        MENUITEM "Paste",                       ID_POPUP_PASTE
        MENUITEM SEPARATOR
        MENUITEM "Delete",                      ID_POPUP_CLEAR
        MENUITEM SEPARATOR
        POPUP "Vector Algebra"
        BEGIN
            MENUITEM "Sum",                         ID_POPUP_VECTORALGEBRA_SUM

            MENUITEM "Difference",                  ID_POPUP_VECTORALGEBRA_DIFFERENCE

            MENUITEM "Cross Product",               ID_POPUP_VECTORALGEBRA_CROSSPRODUCT

        END
        POPUP "Mechanics"
        BEGIN
            POPUP "User Defined Forces"
            BEGIN
                POPUP "Time Independent"
                BEGIN
                    MENUITEM "y-component",                 ID_POPUP_MECHANICS_USERDEFINEDFORCES_TIMEINDEPENDENT_YCOMPONENT

                    MENUITEM "Duffing",                     ID_POPUP_MECHANICS_USERDEFINEDFORCES_TIMEINDEPENDENT_XCOMPONENT

                END
                POPUP "Time Dependent"
                BEGIN
                    MENUITEM "y-component",                 ID_POPUP_MECHANICS_USERDEFINEDFORCES_TIMEDEPENDENT_YCOMPONENT

                    MENUITEM "forced Duffing",              ID_POPUP_MECHANICS_USERDEFINEDFORCES_TIMEDEPENDENT_XCOMPONENT

                END
            END
            POPUP "MultiBody"
            BEGIN
                MENUITEM "Slider",                      ID_POPUP_MECHANICS_MULTIBODY_SLIDER

            END
            POPUP "Oscillators"
            BEGIN
                MENUITEM "Simple Harmonic",             ID_POPUP_OSCILLATORS_SIMPLEHARMONIC

                MENUITEM "Simple Pendulum",             ID_POPUP_OSCILLATORS_SIMPLEPENDULUM

                MENUITEM "Physical Pendulum",           ID_POPUP_CHAOTIC_PHYSICAL_PENDULUM

                MENUITEM "Pendulum and Fixed Charge",   ID_POPUP_CHAOTIC_PENDULUMANDFIXEDCHARGE

            END
            POPUP "Gravitation"
            BEGIN
                MENUITEM "Sun-Earth-Moon",              ID_POPUP_GRAVITATION_SUNEARTHMOON

                MENUITEM "Earth-Moon",                  ID_POPUP_GRAVITATION_EARTHMOON

                MENUITEM "Orbital Mechanics",           ID_POPUP_GRAVITATION_ORBITALMECHANICS

                MENUITEM "Projectile: 2 Balls",         ID_POPUP_PROJECTILE_CANNONBALL

                MENUITEM "Sphere and Blocks",           ID_POPUP_MECHANICS_SPHEREANDBLOCK

                MENUITEM "Two Body",                    ID_POPUP_PROJECTILE_TWOBODY

                MENUITEM "Three Body",                  ID_POPUP_PROJECTILE_THREEBODY

            END
            POPUP "ElectroMagnetic"
            BEGIN
                MENUITEM "Electrostatics",              ID_POPUP_ELECTROMAGNETIC_ELECTROSTATICFIELD

                MENUITEM "Current Loop",                ID_POPUP_ELECTROMAGNETIC_CURRENTLOOP

            END
            MENUITEM "Lnnrd-Jns Ptntl Heated/Cooled", 
                                                    ID_POPUP_MECHANICS_LNNRDJNSPTNTLHEATEDCOOLED

            MENUITEM "Two Blocks and Pulley",       ID_POPUP_MECHANICS_PULLEYANDTWOBLOCKS

            MENUITEM "Free Pulley and Block",       ID_POPUP_MECHANICS_BLOCK_AND_PULLEY

            MENUITEM "Fixed Pulley and Block",      ID_POPUP_MECHANICS_PULLEY

            MENUITEM "Ramp",                        ID_POPUP_MECHANICS_RAMP
            MENUITEM "Ball On Shpere",              ID_POPUP_MECHANICS_BALLONSHPERE

            MENUITEM "Compound Pendulum",           ID_POPUP_CHAOTIC_COMPOUNDPENDULUM

            MENUITEM "Two Body Scattering",         ID_POPUP_MECHANICS_TWOBODY

            MENUITEM "Three Body Collision",        ID_POPUP_MECHANICS_THREEBODY
            , GRAYED
        END
        POPUP "Chaotic"
        BEGIN
            MENUITEM "Logistic Map",                ID_POPUP_CHAOTIC_VERHULSTDYNAMICS

            MENUITEM "Mandelbrot",                  ID_POPUP_CHAOTIC_CHAIN
            MENUITEM "Random Chain",                ID_POPUP_CHAOTIC_RANDOMCHAIN

            MENUITEM "Pendulum and Planar Charge",  ID_POPUP_CHAOTIC_PENDULUMANDPLANARCHARGE

            MENUITEM "Two Body",                    ID_POPUP_CHAOTIC_TWOBODY
            , GRAYED
            MENUITEM "Trapping",                    ID_POPUP_CHAOTIC_TRAPPING
            , GRAYED
            MENUITEM "Six Bodies in Box",           ID_POPUP_CHAOTIC_6BODY
            , GRAYED, HELP
        END
        POPUP "Quantum Mechanics"
        BEGIN
            MENUITEM "Superposition",               ID_POPUP_QUANTUMMECHANICS_SUPERPOSITION

            MENUITEM "Radial l=0 Energy Eigenstates A in 2-Dimensions", 
                                                    ID_POPUP_QUANTUMMECHANICS_STATIONARY_IN_1_SPATIALDIMENSION

            MENUITEM "Radial l=0 Energy Eigenstates B in 2-Dimensions", 
                                                    ID_POPUP_QUANTUMMECHANICS_STATIONARY_IN_1_SPATIALDIMENSIONB

            MENUITEM "2-Dim Hydrogen Energy Eigenstates", 
                                                    ID_POPUP_QUANTUMMECHANICS_Ground_State__IN_1_SPATIALDIMENSION



            MENUITEM "2-Dim BEC L=0 Energy Eigenstate", 
                                                    ID_POPUP_QUANTUMMECHANICS_Ground_State__BEC

            MENUITEM "Scattering in 1 Spatial Dimension", 
                                                    ID_POPUP_QUANTUMMECHANICS_SCATTERINGIN1SPATIALDIMENSION

            MENUITEM "Energy Eigenstate in 2 Spatial Dimensions", 
                                                    ID_POPUP_QUANTUMMECHANICS_STATIONARY_IN_2_SPATIALDIMENSION

        END
        POPUP "Homework"
        BEGIN
            POPUP "College Physics (Serway/Faughn)"
            BEGIN
                POPUP "Chapter"
                BEGIN
                    POPUP "2"
                    BEGIN
                        MENUITEM "Example 2.4",                 ID_POPUP_HOMEWORK_COLLEGEPHYSICSSERWAYFAUGHN_EXAMPLE24

                        MENUITEM "Problem 2.14",                ID_POPUP_HOMEWORK_COLLEGEPHYSICSSERWAYFAUGHN_PROBLEM214

                        MENUITEM "Problem 2.37",                ID_POPUP_HOMEWORK_COLLEGEPHYSICSSERWAYFAUGHN_PROBLEM237

                    END
                    POPUP "3"
                    BEGIN
                        MENUITEM "Problem 3.46",                ID_POPUP_HOMEWORK_COLLEGEPHYSICSSERWAYFAUGHN_PROBLEM346

                        MENUITEM "Problem 3.51",                ID_POPUP_HOMEWORK_COLLEGEPHYSICSSERWAYFAUGHN_PROBLEM351

                        MENUITEM "Problem 3.60",                ID_POPUP_HOMEWORK_COLLEGEPHYSICSSERWAYFAUGHN_PROBLEM360

                    END
                    MENUITEM "4",                           ID_POPUP_HOMEWORK_COLLEGEPHYSICSSERWAYFAUGHN_CHAPTER_4

                    MENUITEM "5",                           ID_POPUP_HOMEWORK_COLLEGEPHYSICSSERWAYFAUGHN_CHAPTER_5

                    MENUITEM "6",                           ID_POPUP_HOMEWORK_COLLEGEPHYSICSSERWAYFAUGHN_CHAPTER_6

                    POPUP "7"
                    BEGIN
                        MENUITEM "Example 7.8",                 ID_POPUP_HOMEWORK_COLLEGEPHYSICSSERWAYFAUGHN_CHAPTER_7_EXAMPLE78

                    END
                END
            END
        END
        POPUP "Graph"
        BEGIN
            MENUITEM "Spline",                      ID_POPUP_Spline
            MENUITEM "Plot",                      ID_POPUP_Test_Plot
        END
        POPUP "Test"
        BEGIN
            MENUITEM "Recursion",                      ID_POPUP_Test_Recursion
        END
    END
END

IDR_MENU_FieldDisplay MENU DISCARDABLE 
BEGIN
    POPUP ""
    BEGIN
        MENUITEM "background",                  ID__BACKGROUND
        POPUP "equipotentials"
        BEGIN
            MENUITEM "show",                        ID__EQUIPOTENTIALS
            MENUITEM "clear",                       ID__clear_EQUIPOTENTIALS
        END
        POPUP "vector fields"
        BEGIN
            MENUITEM "show",                        ID__VECTORFIELDS
            MENUITEM "clear",                       ID__clear_VECTORFIELDS
        END
        POPUP "fieldlines"
        BEGIN
            POPUP "electric"
            BEGIN
                MENUITEM "show",                        ID_electric
                MENUITEM "clear",                       ID_clear_electric
            END
            MENUITEM "magnetic",                    ID_magnetic
            MENUITEM "gravitational",               ID_gravitational
        END
    END
END


